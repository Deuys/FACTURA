<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">

    <style>
        @page {
            margin: 18px 30px 24px;
        }

        body {
            font-family: Inter, DejaVu Sans, sans-serif;
            font-size: 11px;
            color: #111827;
            background: #FFFFFF;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 24px;
            color: #111827;
            letter-spacing: 0.5px;
        }

        .header-table,
        .info-table,
        .lines-table,
        .totals-table,
        .payment-table,
        .legal-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table {
            margin-bottom: 22px;
        }

        .header-table td {
            vertical-align: top;
        }

        .company-name {
            margin-bottom: 6px;
            font-size: 18px;
            font-weight: bold;
            color: #111827;
        }

        .company-details {
            color: #555555;
            line-height: 1.45;
        }

        .factura-brand {
            margin-top: 8px;
            font-size: 9px;
            color: #2563EB;
        }

        .document-title {
            text-align: right;
        }

        .document-number {
            margin-top: 6px;
            color: #555555;
        }

        .info-table {
            margin-bottom: 22px;
        }

        .info-table > tbody > tr > td {
            width: 50%;
            vertical-align: top;
            padding: 12px;
            border: 1px solid #E5E7EB;
            background: #FFFFFF;
        }

        .section-title {
            margin-bottom: 8px;
            font-size: 10px;
            font-weight: bold;
            color: #2563EB;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .info-line {
            margin-bottom: 3px;
        }

        .lines-table {
            table-layout: fixed;
        }

        .lines-table thead {
            display: table-header-group;
        }

        .lines-table tr {
            page-break-inside: avoid;
        }

        .lines-table th,
        .lines-table td {
            padding: 8px;
            border: 1px solid #E5E7EB;
            vertical-align: top;
        }

        .lines-table th {
            background: #EFF6FF;
            color: #111827;
            text-align: left;
            font-weight: bold;
        }

        .lines-table th:nth-child(1) {
            width: 32%;
        }

        .lines-table th:nth-child(2) {
            width: 13%;
        }

        .lines-table th:nth-child(3) {
            width: 14%;
        }

        .lines-table th:nth-child(4) {
            width: 10%;
        }

        .lines-table th:nth-child(5) {
            width: 12%;
        }

        .lines-table th:nth-child(6) {
            width: 19%;
        }

        .lines-table tbody tr:nth-child(even) {
            background: #F8FAFC;
        }

        .designation-description {
            margin-top: 3px;
            color: #555555;
            font-size: 9px;
            line-height: 1.35;
        }

        .text-right {
            text-align: right;
        }

        .totals-wrapper {
            margin-top: 18px;
            page-break-inside: avoid;
        }

        .totals-table {
            width: 44%;
            margin-left: auto;
        }

        .totals-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #E5E7EB;
        }

        .total-ttc td {
            padding-top: 10px;
            padding-bottom: 10px;
            color: #2563EB;
            background: #EFF6FF;
            font-size: 14px;
            font-weight: bold;
            border-top: 2px solid #2563EB;
            border-bottom: 2px solid #2563EB;
        }

        .payment-wrapper {
            margin-top: 18px;
            page-break-inside: avoid;
        }

        .payment-table td {
            width: 50%;
            vertical-align: top;
            padding: 12px;
            border: 1px solid #E5E7EB;
        }

        .payment-label {
            color: #555555;
        }

        .payment-value {
            margin-top: 2px;
            font-weight: bold;
            color: #111827;
        }

        .bank-details {
            margin-top: 8px;
            padding: 10px;
            background: #F8FAFC;
            border: 1px solid #E5E7EB;
        }

        .comment {
            margin-top: 16px;
            padding: 10px;
            background: #F8FAFC;
            border: 1px solid #E5E7EB;
            color: #555555;
        }

        .comment strong {
            color: #111827;
        }

        .legal-block {
            margin-top: 10px;
            padding-top: 6px;
            border-top: 1px solid #E5E7EB;
            color: #555555;
            font-size: 7.5px;
            line-height: 1.2;
        }

        .footer {
            position: fixed;
            right: 0;
            bottom: -20px;
            left: 0;
            color: #555555;
            font-size: 7px;
            text-align: center;
        }
    </style>
</head>

<body>
{% set entreprise = facture.user.entreprise %}

<table class="header-table">
    <tr>
        <td>
            {% if entreprise %}
                <div class="company-name">
                    {{ entreprise.nom }}
                </div>

                <div class="company-details">
                    <div>{{ entreprise.adresse }}</div>
                    <div>
                        {{ entreprise.codePostal }}
                        {{ entreprise.ville }}
                    </div>

                    {% if entreprise.pays %}
                        <div>{{ entreprise.pays }}</div>
                    {% endif %}

                    {% if entreprise.telephone %}
                        <div>Tél. : {{ entreprise.telephone }}</div>
                    {% endif %}

                    {% if entreprise.email %}
                        <div>{{ entreprise.email }}</div>
                    {% endif %}

                    {% if entreprise.siret %}
                        <div>SIRET : {{ entreprise.siret }}</div>
                    {% endif %}

                    {% if entreprise.tvaIntracom %}
                        <div>TVA intracom. : {{ entreprise.tvaIntracom }}</div>
                    {% endif %}
                </div>

                <div class="factura-brand">
                    Document généré avec FACTURA
                </div>
            {% else %}
                <div class="company-name">FACTURA</div>
            {% endif %}
        </td>

        <td class="document-title">
            <h1>FACTURE</h1>

            <div class="document-number">
                {{ facture.numero }}
            </div>
        </td>
    </tr>
</table>

<table class="info-table">
    <tr>
        <td>
            <div class="section-title">Facturé à</div>

            <div>
                {{ facture.client.prenom }}
                {{ facture.client.nom }}
            </div>

            {% if facture.client.entreprise %}
                <div>{{ facture.client.entreprise }}</div>
            {% endif %}

            {% if facture.client.email %}
                <div>{{ facture.client.email }}</div>
            {% endif %}

            {% if facture.client.adresse %}
                <div>{{ facture.client.adresse }}</div>
            {% endif %}

            <div>
                {{ facture.client.codePostal }}
                {{ facture.client.ville }}
            </div>

            {% if facture.client.pays %}
                <div>{{ facture.client.pays }}</div>
            {% endif %}
        </td>

        <td>
            <div class="section-title">Informations</div>

            <div class="info-line">
                Date d’émission :
                {{ facture.dateEmission|date('d/m/Y') }}
            </div>

            <div class="info-line">
                Date d’échéance :
                {{ facture.dateEcheance|date('d/m/Y') }}
            </div>

            <div class="info-line">
                Référence :
                {{ facture.numero }}
            </div>
        </td>
    </tr>
</table>

<table class="lines-table">
    <thead>
    <tr>
        <th>Désignation</th>
        <th class="text-right">Qté / Unité</th>
        <th class="text-right">Prix HT</th>
        <th class="text-right">TVA</th>
        <th class="text-right">Remise</th>
        <th class="text-right">Total HT</th>
    </tr>
    </thead>

    <tbody>
    {% for ligne in facture.ligneFactures %}
        <tr>
            <td>
                <strong>{{ ligne.designation }}</strong>

                {% if ligne.description %}
                    <div class="designation-description">
                        {{ ligne.description }}
                    </div>
                {% endif %}
            </td>

            <td class="text-right">
                {% set quantite = ligne.quantite + 0 %}

                {% if quantite == quantite|round(0, 'floor') %}
                    {{ quantite|number_format(0, ',', ' ') }}
                {% else %}
                    {{ quantite|number_format(2, ',', ' ') }}
                {% endif %}

                {% if ligne.unite %}
                    {{ ligne.unite }}
                {% endif %}
            </td>

            <td class="text-right">
                {{ ligne.prixUnitaireHT|number_format(2, ',', ' ') }} €
            </td>

            <td class="text-right">
                {{ ligne.tva|number_format(2, ',', ' ') }} %
            </td>

            <td class="text-right">
                {{ ligne.remise|default('0')|number_format(2, ',', ' ') }} %
            </td>

            <td class="text-right">
                {{ ligne.totalHT|number_format(2, ',', ' ') }} €
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6">
                Aucune ligne de facture.
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="totals-wrapper">
    <table class="totals-table">
        <tr>
            <td>Total HT</td>
            <td class="text-right">
                {{ facture.totalHT|number_format(2, ',', ' ') }} €
            </td>
        </tr>

        <tr>
            <td>
                TVA
                {% if entreprise %}
                    {{ entreprise.tauxTvaDefaut|number_format(2, ',', ' ') }} %
                {% endif %}
            </td>
            <td class="text-right">
                {{ facture.totalTVA|number_format(2, ',', ' ') }} €
            </td>
        </tr>

        <tr class="total-ttc">
            <td>TOTAL TTC</td>
            <td class="text-right">
                {{ facture.totalTTC|number_format(2, ',', ' ') }} €
            </td>
        </tr>
    </table>
</div>

{% if entreprise %}
    <div class="payment-wrapper">
        <div class="section-title">Règlement</div>

        <table class="payment-table">
            <tr>
                <td>
                    <div class="payment-label">Conditions de règlement</div>
                    <div class="payment-value">
                        {% if entreprise.conditionsReglement %}
                            {{ entreprise.conditionsReglement|nl2br }}
                        {% else %}
                            Paiement à {{ entreprise.delaiPaiement }} jours
                        {% endif %}
                    </div>
                </td>

                <td>
                    <div class="payment-label">Date limite de paiement</div>
                    <div class="payment-value">
                        {{ facture.dateEcheance|date('d/m/Y') }}
                    </div>
                </td>
            </tr>

            <tr>
                <td>
                    <div class="payment-label">Mode de paiement</div>
                    <div class="payment-value">
                        {{ entreprise.modePaiementDefaut.value }}
                    </div>
                </td>

                <td>
                    <div class="payment-label">Référence à rappeler</div>
                    <div class="payment-value">
                        {{ facture.numero }}
                    </div>
                </td>
            </tr>
        </table>

        {% if entreprise.iban or entreprise.bic %}
            <div class="bank-details">
                {% if entreprise.iban %}
                    <div>
                        <strong>IBAN :</strong>
                        {{ entreprise.iban }}
                    </div>
                {% endif %}

                {% if entreprise.bic %}
                    <div>
                        <strong>BIC :</strong>
                        {{ entreprise.bic }}
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endif %}

{% if facture.commentaire %}
    <div class="comment">
        <strong>Notes</strong>
        <br><br>
        {{ facture.commentaire|nl2br }}
    </div>
{% endif %}

{% if entreprise %}
    <div class="legal-block">
        {% if entreprise.formeJuridique %}
            {{ entreprise.formeJuridique }}
        {% endif %}

        {% if entreprise.capitalSocial %}
            — Capital social :
            {{ entreprise.capitalSocial|number_format(2, ',', ' ') }} €
        {% endif %}

        {% if entreprise.rcs %}
            — RCS
            {% if entreprise.villeRcs %}
                {{ entreprise.villeRcs }}
            {% endif %}
            {{ entreprise.rcs }}
        {% endif %}

        {% if entreprise.formeJuridique
            or entreprise.capitalSocial
            or entreprise.rcs
        %}
            <br>
        {% endif %}

        {% if entreprise.escomptePaiementAnticipe %}
            Escompte pour paiement anticipé :
            {{ entreprise.escomptePaiementAnticipe }}
        {% else %}
            Escompte pour paiement anticipé : néant.
        {% endif %}

        — Pénalités de retard :
        {{ entreprise.tauxPenalitesRetard|number_format(2, ',', ' ') }} %

        — Indemnité forfaitaire pour frais de recouvrement :
        {{ entreprise.indemniteRecouvrement|number_format(2, ',', ' ') }} €

        {% if entreprise.mentionTva %}
            <br>
            {{ entreprise.mentionTva|nl2br }}
        {% endif %}
    </div>
{% endif %}

<div class="footer">
    {% if entreprise %}
        {{ entreprise.nom }}
        {% if entreprise.siret %}
            — SIRET {{ entreprise.siret }}
        {% endif %}
        —
    {% endif %}

    Facture {{ facture.numero }} — Document généré avec FACTURA
</div>
</body>
</html>